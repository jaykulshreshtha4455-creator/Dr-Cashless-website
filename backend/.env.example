# Copy this to .env and fill in your values

# PostgreSQL connection (from Railway dashboard)
DATABASE_URL=postgresql://user:password@host:port/dbname

# JWT secret for admin sessions (generate a random string)
JWT_SECRET=change_this_to_a_random_secret_string

# Admin credentials (set these before first run)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password

# Allowed origins for CORS (comma-separated, your GitHub Pages URL)
ALLOWED_ORIGINS=https://yourusername.github.io,http://localhost:5500

# Port (Railway sets this automatically)
PORT=3000
